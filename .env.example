# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: PostgreSQL connection string
# Set this to your PostgreSQL instance (e.g. Supabase, Vercel Postgres, Neon)
DATABASE_URL="postgres://user:pass@host:5432/db"

# AUTH_SECRET: Random string used to hash tokens, sign/encrypt cookies and generate cryptographic keys.
# Generate one using `openssl rand -base64 32` or `npx auth secret`
AUTH_SECRET="itbusiness_secret_key_change_me_in_prod"

# NEXT_PUBLIC_APP_URL: Public URL of the app
NEXT_PUBLIC_APP_URL="http://localhost:3000"
