# =============================================================
# VARIABLES D'ENVIRONNEMENT — À configurer sur Vercel Dashboard
# Settings → Environment Variables
# =============================================================

# GEMINI_API_KEY: Clé API Google Gemini
# Obtenir sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# DATABASE_URL: Connexion PostgreSQL (Neon recommandé — gratuit)
# 1. Créer un compte sur https://neon.tech
# 2. Créer un projet → copier la connection string
# Format : postgres://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# AUTH_SECRET: Clé secrète pour NextAuth (OBLIGATOIRE en prod)
# Générer avec : openssl rand -base64 32
# Ou avec     : npx auth secret
AUTH_SECRET="remplacer_par_une_cle_aleatoire_generee"

# NEXT_PUBLIC_APP_URL: URL publique de l'application
# Exemple : https://mon-app.vercel.app
NEXT_PUBLIC_APP_URL="https://ton-app.vercel.app"
